{
  "$schema": "https://raw.githubusercontent.com/oh-my-tab/oh-my-tab/main/.schemas/tauri.conf.json",
  "productName": "Oh My Tab",
  "version": "0.1.0",
  "identifier": "com.oh-my-tab.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "overlay",
        "title": "",
        "width": 280,
        "height": 60,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "focus": true,
        "center": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
